<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- TOOLBAR -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_dark"
        android:elevation="4dp"
        android:fontFamily="@font/alegreya_bold"
        app:title="Pariwisata Desa"
        app:titleTextColor="@color/text_light"
        app:titleTextAppearance="@style/TextAppearance.AppCompat.Large"
        app:titleMarginStart="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@color/hijau">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- LOGO -->
            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_marginTop="20dp"
                android:src="@drawable/logopariwisata" />

            <!-- GREETING -->
            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Selamat Datang!"
                android:fontFamily="@font/alegreya_bold"
                android:textColor="@color/primary_dark"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- SUBTITLE -->
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="Sistem Administrasi Pariwisata dan Homestay Desa"
                android:fontFamily="@font/alegreya_medium"
                android:textColor="@color/primary_soft"
                android:textSize="16sp" />

            <!-- GARIS PEMISAH -->
            <View
                android:layout_width="60dp"
                android:layout_height="3dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="40dp"
                android:background="@color/primary_soft" />

            <!-- BUTTON 1: KALKULATOR BANGUN RUANG -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">

                <Button
                    android:id="@+id/btnSecondActivity"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="@color/white"
                    android:text="Kalkulator Bangun Ruang"
                    android:fontFamily="@font/alegreya_bold"
                    android:textColor="@color/primary_dark"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:elevation="0dp"
                    android:foreground="?attr/selectableItemBackground" />

            </androidx.cardview.widget.CardView>

            <!-- BUTTON 2: MEDITASI -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">

                <Button
                    android:id="@+id/btnMeditation"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="@color/white"
                    android:text="Meditasi dan Relaksasi"
                    android:fontFamily="@font/alegreya_bold"
                    android:textColor="@color/primary_dark"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:elevation="0dp"
                    android:foreground="?attr/selectableItemBackground" />

            </androidx.cardview.widget.CardView>

            <!-- BUTTON 3: FOKUS & HIDUP SEHAT -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">

                <Button
                    android:id="@+id/btnFocusHealth"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="@color/white"
                    android:text="Fokus dan Hidup Sehat"
                    android:fontFamily="@font/alegreya_bold"
                    android:textColor="@color/primary_dark"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:elevation="0dp"
                    android:foreground="?attr/selectableItemBackground" />

            </androidx.cardview.widget.CardView>

            <!-- BUTTON 4: WEBSITE BINA DESA -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">

                <Button
                    android:id="@+id/btnWebView"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="@color/white"
                    android:text="Website Pariwisata Desa"
                    android:fontFamily="@font/alegreya_bold"
                    android:textColor="@color/primary_dark"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:elevation="0dp"
                    android:foreground="?attr/selectableItemBackground" />

            </androidx.cardview.widget.CardView>

            <!-- BUTTON 5: PERTEMUAN 9 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">

                <Button
                    android:id="@+id/btnPertemuan9"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="@color/white"
                    android:text="Pertemuan 9"
                    android:fontFamily="@font/alegreya_bold"
                    android:textColor="@color/primary_dark"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:elevation="0dp"
                    android:foreground="?attr/selectableItemBackground" />

            </androidx.cardview.widget.CardView>

            <!-- BUTTON 6: PERTEMUAN 10 - TABLAYOUT & RECYCLERVIEW -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">

                <Button
                    android:id="@+id/btnPertemuan10"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="@color/white"
                    android:text="Pertemuan 10 - Wisata Desa"
                    android:fontFamily="@font/alegreya_bold"
                    android:textColor="@color/primary_dark"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:elevation="0dp"
                    android:foreground="?attr/selectableItemBackground" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>