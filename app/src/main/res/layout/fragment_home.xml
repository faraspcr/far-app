<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- TOOLBAR -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_dark"
        android:elevation="4dp"
        android:fontFamily="@font/alegreya_bold"
        app:title="Pariwisata Desa"
        app:titleTextColor="@color/text_light"
        app:titleTextAppearance="@style/TextAppearance.AppCompat.Large"
        app:titleMarginStart="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@color/hijau">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_marginTop="20dp"
                android:src="@drawable/logopariwisata" />

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Selamat Datang!"
                android:fontFamily="@font/alegreya_bold"
                android:textColor="@color/primary_dark"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="Sistem Administrasi Pariwisata dan Homestay Desa"
                android:fontFamily="@font/alegreya_medium"
                android:textColor="@color/primary_soft"
                android:textSize="16sp" />

            <View
                android:layout_width="60dp"
                android:layout_height="3dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="40dp"
                android:background="@color/primary_soft" />

            <Button
                android:id="@+id/btnSecondActivity"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@color/primary_soft"
                android:text="Kalkulator Bangun Ruang"
                android:fontFamily="@font/alegreya_bold"
                android:textColor="@color/text_light"
                android:textSize="16sp"
                android:elevation="2dp" />

            <Button
                android:id="@+id/btnMeditation"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#2E6B3E"
                android:text="Meditasi dan Relaksasi"
                android:fontFamily="@font/alegreya_bold"
                android:textColor="@color/text_light"
                android:textSize="16sp"
                android:elevation="2dp" />

            <Button
                android:id="@+id/btnFocusHealth"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#3F8A50"
                android:text="Fokus dan Hidup Sehat"
                android:fontFamily="@font/alegreya_bold"
                android:textColor="@color/text_light"
                android:textSize="16sp"
                android:elevation="2dp" />

            <Button
                android:id="@+id/btnWebView"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#55A86B"
                android:text="Website Pariwisata Desa"
                android:fontFamily="@font/alegreya_bold"
                android:textColor="@color/text_light"
                android:textSize="16sp"
                android:elevation="2dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>