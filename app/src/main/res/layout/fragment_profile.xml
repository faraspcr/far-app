<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- TOOLBAR SAMA SEPERTI HOME & ABOUT -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_dark"
        android:elevation="4dp"
        android:fontFamily="@font/alegreya_bold"
        app:title="Profile Saya"
        app:titleTextColor="@color/text_light"
        app:titleMarginStart="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/hijau"
        android:paddingTop="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- FOTO & ABOUT CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        app:cardCornerRadius="45dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#E8F5E9">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/faraszakia"
                            android:scaleType="centerCrop"
                            android:contentDescription="Foto Profile" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Faras Zakia"
                            android:fontFamily="@font/alegreya_bold"
                            android:textSize="20sp"
                            android:textColor="#2E7D32" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="frszakiaa_"
                            android:fontFamily="@font/alegreya_regular"
                            android:textSize="12sp"
                            android:textColor="#81C784"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mahasiswa | Sistem Informasi"
                            android:fontFamily="@font/alegreya_regular"
                            android:textSize="12sp"
                            android:textColor="#757575"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- BIO CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📝 Tentang Saya"
                        android:fontFamily="@font/alegreya_bold"
                        android:textSize="16sp"
                        android:textColor="#2E7D32"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Saya adalah mahasiswa yang sedang mendalami pengembangan aplikasi Android. Tertarik pada teknologi digital untuk memberdayakan masyarakat desa melalui aplikasi pariwisata dan homestay."
                        android:fontFamily="@font/alegreya_regular"
                        android:textSize="13sp"
                        android:textColor="#555555"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- DETAIL CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ℹ️ Informasi Detail"
                        android:fontFamily="@font/alegreya_bold"
                        android:textSize="16sp"
                        android:textColor="#2E7D32"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nama Lengkap"
                        android:fontFamily="@font/alegreya_bold"
                        android:textSize="12sp"
                        android:textColor="#388E3C" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Faras Zakia Indrani"
                        android:fontFamily="@font/alegreya_regular"
                        android:textSize="13sp"
                        android:textColor="#333333"
                        android:layout_marginBottom="12dp" />


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:fontFamily="@font/alegreya_bold"
                        android:textSize="12sp"
                        android:textColor="#388E3C" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="faras24si@mahasiswa.pcr.ac.id"
                        android:fontFamily="@font/alegreya_regular"
                        android:textSize="13sp"
                        android:textColor="#333333"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Project Saat Ini"
                        android:fontFamily="@font/alegreya_bold"
                        android:textSize="12sp"
                        android:textColor="#388E3C" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pariwisata Desa - Aplikasi Pariwisata dan Homestay"
                        android:fontFamily="@font/alegreya_regular"
                        android:textSize="13sp"
                        android:textColor="#333333"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lokasi"
                        android:fontFamily="@font/alegreya_bold"
                        android:textSize="12sp"
                        android:textColor="#388E3C" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pekanbaru, Riau, Indonesia"
                        android:fontFamily="@font/alegreya_regular"
                        android:textSize="13sp"
                        android:textColor="#333333" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SOSIAL MEDIA CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔗 Sosial Media"
                        android:fontFamily="@font/alegreya_bold"
                        android:textSize="14sp"
                        android:textColor="#2E7D32"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/icGithub"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_github"
                            android:padding="12dp"
                            android:layout_marginEnd="24dp"
                            android:background="@drawable/bg_sosial"
                            android:contentDescription="GitHub" />

                        <ImageView
                            android:id="@+id/icLinkedin"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_linkedin"
                            android:padding="12dp"
                            android:layout_marginEnd="24dp"
                            android:background="@drawable/bg_sosial"
                            android:contentDescription="LinkedIn" />

                        <ImageView
                            android:id="@+id/icInstagram"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_instagram"
                            android:padding="12dp"
                            android:background="@drawable/bg_sosial"
                            android:contentDescription="Instagram" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TOMBOL LOGOUT (DI BAWAH SOSIAL MEDIA) -->
            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#FF6B6B"
                android:text="Logout"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- FOOTER -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✨ Pariwisata Desa - Digitalisasi Pariwisata Desa ✨"
                android:textSize="11sp"
                android:textColor="@color/text_dark"
                android:gravity="center"
                android:padding="16dp"
                android:fontFamily="@font/alegreya_regular" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>