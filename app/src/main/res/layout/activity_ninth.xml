<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hijau">

    <!-- ==================== BACKGROUND WAVE ==================== -->
    <View
        android:id="@+id/background_header"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:background="@drawable/bg_header_wave"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ==================== TOOLBAR ==================== -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarNinth"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="Layanan Desa"
        app:titleTextColor="@color/text_light" />

    <!-- ==================== SCROLL VIEW ==================== -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbarNinth">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingTop="24dp">

            <!-- =============================== -->
            <!-- 1. CHIP & CHIPGROUP -->
            <!-- =============================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏷️ Filter Kategori"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_dark"
                        android:fontFamily="@font/alegreya_bold"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupFilter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipAlam"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="🌿 Alam" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipKuliner"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🍜 Kuliner" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipBudaya"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎭 Budaya" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipHomestay"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏡 Homestay" />

                    </com.google.android.material.chip.ChipGroup>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- =============================== -->
            <!-- 2. GRIDLAYOUT MENU KOTAK-KOTAK -->
            <!-- =============================== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menu Layanan"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_dark"
                android:fontFamily="@font/alegreya_bold"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp" />

            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/gridLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:columnCount="2"
                android:layout_marginBottom="24dp">

                <!-- Kotak 1: Destinasi -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:id="@+id/menuDestinasi">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@android:drawable/ic_menu_mapmode" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Destinasi"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_dark"
                            android:fontFamily="@font/alegreya_bold"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lihat wisata"
                            android:textSize="10sp"
                            android:textColor="@color/text_gray"
                            android:fontFamily="@font/alegreya_regular" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Kotak 2: Homestay -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:id="@+id/menuHomestay">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@android:drawable/ic_menu_mylocation" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Homestay"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_dark"
                            android:fontFamily="@font/alegreya_bold"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cari homestay"
                            android:textSize="10sp"
                            android:textColor="@color/text_gray"
                            android:fontFamily="@font/alegreya_regular" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Kotak 3: Event -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:id="@+id/menuEvent">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@android:drawable/ic_menu_agenda" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Event"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_dark"
                            android:fontFamily="@font/alegreya_bold"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Info acara"
                            android:textSize="10sp"
                            android:textColor="@color/text_gray"
                            android:fontFamily="@font/alegreya_regular" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Kotak 4: Kuliner -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:id="@+id/menuKuliner">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@android:drawable/ic_menu_edit" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kuliner"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_dark"
                            android:fontFamily="@font/alegreya_bold"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Makanan khas"
                            android:textSize="10sp"
                            android:textColor="@color/text_gray"
                            android:fontFamily="@font/alegreya_regular" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Kotak 5: Oleh-oleh -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:id="@+id/menuOlehOleh">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@android:drawable/ic_menu_gallery" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Oleh-oleh"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_dark"
                            android:fontFamily="@font/alegreya_bold"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Buah tangan"
                            android:textSize="10sp"
                            android:textColor="@color/text_gray"
                            android:fontFamily="@font/alegreya_regular" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Kotak 6: Transport -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:id="@+id/menuTransport">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@android:drawable/ic_menu_directions" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Transport"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_dark"
                            android:fontFamily="@font/alegreya_bold"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Akomodasi"
                            android:textSize="10sp"
                            android:textColor="@color/text_gray"
                            android:fontFamily="@font/alegreya_regular" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </androidx.gridlayout.widget.GridLayout>

            <!-- =============================== -->
            <!-- 3. TEXTINPUTLAYOUT (EMAIL & PASSWORD) DENGAN ICON -->
            <!-- =============================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔐 Login Anggota"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_dark"
                        android:fontFamily="@font/alegreya_bold"
                        android:layout_marginBottom="16dp" />

                    <!-- Email dengan icon email -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilEmail"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Email"
                        app:startIconDrawable="@android:drawable/ic_dialog_email">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password dengan icon gembok -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPassword"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Password"
                        app:endIconMode="password_toggle"
                        app:startIconDrawable="@android:drawable/ic_lock_lock">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Tombol Login -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="20dp"
                        android:text="Login"
                        android:textSize="14sp"
                        app:icon="@android:drawable/ic_menu_save"
                        app:iconGravity="textStart"
                        app:cornerRadius="12dp"
                        android:backgroundTint="@color/primary_soft" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- =============================== -->
            <!-- 4. TOMBOL LISTVIEW DESTINASI -->
            <!-- =============================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌍 Destinasi Wisata"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_dark"
                        android:fontFamily="@font/alegreya_bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lihat kumpulan destinasi wisata desa lengkap dengan gambar"
                        android:textSize="12sp"
                        android:textColor="@color/text_gray"
                        android:fontFamily="@font/alegreya_regular"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLihatDestinasi"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Lihat Destinasi"
                        android:textSize="14sp"
                        app:icon="@android:drawable/ic_menu_view"
                        app:iconGravity="textStart"
                        app:cornerRadius="12dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>