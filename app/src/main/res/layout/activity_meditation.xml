<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary_soft"
            app:titleTextColor="@color/text_light" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_meditation"
                android:scaleType="centerCrop" />

            <View
                android:layout_width="match_parent"
                android:layout_height="382dp"
                android:layout_gravity="bottom"
                android:background="#CC000000" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal"
                android:layout_gravity="bottom">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/alegreya_bold"
                    android:text="MEDITATION"
                    android:textColor="#FFFFFF"
                    android:textSize="40sp"
                    android:gravity="start" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/alegreya_sans_regular"
                    android:text="BENEFITS FOR"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:gravity="start" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/alegreya_sans_regular"
                    android:text="THE MIND AND BODY"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:gravity="start" />

                <View
                    android:layout_width="60dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="20dp"
                    android:background="@color/primary_soft"
                    android:layout_gravity="start" />

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/alegreya_sans_regular"
                    android:text="Find your inner peace with guided meditation"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="start" />

                <Button
                    android:id="@+id/btnLearnMore"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="@color/primary_soft"
                    android:fontFamily="@font/alegreya_bold"
                    android:text="Start Your Meditation Journey"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:layout_gravity="start" />

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

</FrameLayout>