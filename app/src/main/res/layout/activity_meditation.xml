<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/ic_meditation"
        android:scaleType="centerCrop" />

    <!-- OVERLAY GELAP - DIPERKECIL -->
    <View
        android:layout_width="match_parent"
        android:layout_height="382dp"
        android:layout_gravity="bottom"
        android:background="#CC000000" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@color/primary_soft"
                android:gravity="center"
                android:text="←"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:clickable="true"
                android:focusable="true"
                android:layout_gravity="start"
                android:elevation="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="139dp"
                android:layout_weight="10" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/alegreya_bold"
                android:text="MEDITATION"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:letterSpacing="0.05"
                android:shadowColor="#000000"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:gravity="start" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/alegreya_sans_regular"
                android:text="BENEFITS FOR"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:shadowColor="#000000"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:gravity="start" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/alegreya_sans_regular"
                android:text="THE MIND AND BODY"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:shadowColor="#000000"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:gravity="start" />

            <View
                android:layout_width="60dp"
                android:layout_height="2dp"
                android:layout_marginTop="20dp"
                android:background="@color/primary_soft"
                android:layout_gravity="start" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/alegreya_sans_regular"
                android:text="Find your inner peace with guided meditation"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="start"
                android:lineSpacingExtra="4dp"
                android:shadowColor="#000000"
                android:shadowDy="1"
                android:shadowRadius="2" />

            <Button
                android:id="@+id/btnLearnMore"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/primary_soft"
                android:fontFamily="@font/alegreya_bold"
                android:text="Start Your Meditation Journey"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:layout_gravity="start" />

            <!-- HAPUS TEKS "BENEFITS" PUTIH, LANGSUNG CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="40dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/alegreya_sans_regular"
                        android:text="30min"
                        android:textColor="#888888"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/alegreya_bold"
                        android:text="YOU SHOULD NEVER"
                        android:textColor="#253334"
                        android:textSize="18sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/alegreya_sans_regular"
                            android:text="✓ Reduce stress and anxiety"
                            android:textColor="#444444"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/alegreya_sans_regular"
                            android:text="✓ Improve focus and concentration"
                            android:textColor="#444444"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/alegreya_sans_regular"
                            android:text="✓ Better sleep quality"
                            android:textColor="#444444"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>



</FrameLayout>