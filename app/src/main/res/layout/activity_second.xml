<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal"
    android:background="#E8F4FD">

    <TextView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="#7C9A92"
        android:gravity="center"
        android:text="←"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:clickable="true"
        android:focusable="true"
        android:layout_gravity="start" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📐 Kalkulator"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1B5E20"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="══════════════════"
        android:textSize="16sp"
        android:textColor="#4CAF50"
        android:layout_marginBottom="30dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚪ Jari-jari (r)"
        android:textSize="14sp"
        android:textColor="#333"
        android:layout_marginBottom="5dp"
        android:layout_gravity="start"/>

    <EditText
        android:id="@+id/inputJari"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Masukkan Jari-jari"
        android:inputType="numberDecimal"
        android:background="@android:drawable/editbox_background"
        android:padding="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📏 Tinggi (t)"
        android:textSize="14sp"
        android:textColor="#333"
        android:layout_marginTop="15dp"
        android:layout_marginBottom="5dp"
        android:layout_gravity="start"/>

    <EditText
        android:id="@+id/inputTinggi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Masukkan Tinggi (Hanya untuk Volume Tabung)"
        android:inputType="numberDecimal"
        android:background="@android:drawable/editbox_background"
        android:padding="12dp"/>

    <Button
        android:id="@+id/btnLuas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🟢 Hitung Luas Lingkaran"
        android:layout_marginTop="20dp"
        android:backgroundTint="#4CAF50"
        android:padding="14dp"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"/>

    <Button
        android:id="@+id/btnVolume"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔵 Hitung Volume Tabung"
        android:layout_marginTop="10dp"
        android:backgroundTint="#2196F3"
        android:padding="14dp"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCC"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/tvHasil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hasil: 0"
        android:textSize="22sp"
        android:textColor="#1B5E20"
        android:textStyle="bold"
        android:gravity="center"
        android:background="#FFFFFF"
        android:padding="20dp"/>

</LinearLayout>